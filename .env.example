# Supabase Dashboard -> Connect -> Session pooler. Keep this server-only.
# Use the port 5432 connection string and URL-encode special characters in the password.
SUPABASE_SESSION_POOLER_URL=postgresql://postgres.PROJECT_REF:URL_ENCODED_PASSWORD@SESSION_POOLER_HOST:5432/postgres

# Keep the application-side pool small because Session Pool reserves one backend
# connection per active client connection.
SUPABASE_SESSION_POOL_MAX=5
