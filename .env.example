# Supabase Dashboard > Connect > Session pooler. Keep this server-only.
# Replace PROJECT_REF and REGION; URL-encode special characters in the password.
SUPABASE_SESSION_POOLER_URL=postgresql://postgres.PROJECT_REF:YOUR_URL_ENCODED_DATABASE_PASSWORD@aws-1-REGION.pooler.supabase.com:5432/postgres?sslmode=verify-full
SUPABASE_CA_CERT_PATH=/absolute/path/to/prod-ca-2021.crt

# Session Pool reserves one backend connection per client, so keep the local pool small.
SUPABASE_SESSION_POOL_MAX=3

# Server-side Firecrawl API key. Never prefix this variable with NEXT_PUBLIC_.
# Optional. When blank, collection uses the compliant direct fallback.
FIRECRAWL_API_KEY=

# Seed runner target. Change this only if Next.js starts on another port.
EU_MASTER_BASE_URL=http://localhost:3000

# Optional. Defaults to <project>/Private_Data and <project>/material_center.
EU_MASTER_PRIVATE_DATA_DIR=
EU_MASTER_MATERIAL_DIR=

# Legacy local-data migration source only. Leave blank for the repository default.
EU_MASTER_DATA_DIR=
